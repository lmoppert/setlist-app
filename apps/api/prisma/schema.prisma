generator client {
  provider = "prisma-client"
  output   = "../src/app/database" 
}

datasource db {
  provider = "postgresql"
}

model Song {
  id          String       @id @default(uuid())
  slug        String       @unique
  title       String
  artist      String?
  duration    Int          // in seconds
  tempo       Int?
  key         String?
  
  assignments Assignment[]
  entries     SetlistEntry[]
}

model Member {
  id             String       @id @default(uuid())
  name           String
  mainInstrument String
  
  assignments    Assignment[]
}

model Assignment {
  id         String  @id @default(uuid())
  songId     String
  memberId   String
  instrument String
  tuning     String? // Falls ein Musiker für diesen Song umstimmen muss
  isLead     Boolean @default(false)

  song       Song    @relation(fields: [songId], references: [id])
  member     Member  @relation(fields: [memberId], references: [id])
}

model Setlist {
  id        String   @id @default(uuid())
  slug      String   @unique
  date      DateTime?
  location  String

  name      String?
  duration  Int?
  
  entries SetlistEntry[]
}

model SetlistEntry {
  id         String  @id @default(uuid())
  position   Int
  isOptional Boolean @default(false)
  isEncore   Boolean @default(false)

  setlistId  String
  setlist    Setlist @relation(fields: [setlistId], references: [id], onDelete: Cascade)
  
  songId     String
  song       Song    @relation(fields: [songId], references: [id])

  @@index([setlistId, position])
}