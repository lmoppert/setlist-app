generator client {
  provider = "prisma-client"
  output   = "../src/app/database" 
}

datasource db {
  provider = "postgresql"
}

model Song {
  id          String       @id @default(uuid())
  slug        String       @unique
  isActive    Boolean      @default(true)
  title       String
  artist      String?
  duration    Int          // in seconds
  tempo       Int?
  key         String?
  leadVocals  String?
  
  instruments Instrument[]
  resources   SongResource[]
  entries     SetlistEntry[]
}

model SongResource {
  id        String   @id @default(uuid())
  type      String   // 'CHORDS', 'BASS', 'AKK', 'LYRICS'
  filetype  String   // 'PDF', 'TXT', 'MD'
  path      String

  songId    String
  song      Song    @relation(fields: [songId], references: [id], onDelete: Cascade)
}

model Member {
  id             String       @id @default(uuid())
  name           String       @unique
  isLeadVocalist Boolean      @default(false)
  
  instruments    Instrument[]
}

model Instrument {
  id         String  @id @default(uuid())
  name       String
  tuning     String?

  songId     String
  song       Song    @relation(fields: [songId], references: [id], onDelete: Cascade)
  
  memberId   String
  member     Member  @relation(fields: [memberId], references: [id])
}

model Setlist {
  id        String   @id @default(uuid())
  slug      String   @unique
  date      DateTime?
  location  String

  name      String?
  duration  Int?
  
  entries   SetlistEntry[]
}

model SetlistEntry {
  id         String  @id @default(uuid())
  position   Int
  isAccustic Boolean @default(false)
  isEncore   Boolean @default(false)

  setlistId  String
  setlist    Setlist @relation(fields: [setlistId], references: [id], onDelete: Cascade)
  
  songId     String
  song       Song    @relation(fields: [songId], references: [id])

  @@index([setlistId, position])
}